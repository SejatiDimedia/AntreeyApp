{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile with role-based access and risk indicators.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["customer", "owner"] },
        "cancelCount": { "type": "integer" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "email", "role"]
    },
    "Business": {
      "title": "Business",
      "description": "Shop information.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "ownerId": { "type": "string" },
        "name": { "type": "string" },
        "address": { "type": "string" },
        "avgDurationMinutes": { "type": "integer" },
        "efficiencyFactor": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "ownerId", "name"]
    },
    "Service": {
      "title": "Service",
      "description": "Services offered by a business.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "businessId": { "type": "string" },
        "name": { "type": "string" },
        "duration": { "type": "integer" },
        "price": { "type": "number" }
      },
      "required": ["id", "businessId", "name", "duration"]
    },
    "Booking": {
      "title": "Booking",
      "description": "Queue entry or scheduled booking.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "businessId": { "type": "string" },
        "userId": { "type": "string" },
        "serviceId": { "type": "string" },
        "staffId": { "type": "string" },
        "requestedTime": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "completed", "cancelled"] },
        "queuePosition": { "type": "integer" },
        "isHighRisk": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "businessId", "userId", "serviceId", "status"]
    },
    "Staff": {
      "title": "Staff",
      "description": "Staff members availability.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "businessId": { "type": "string" },
        "name": { "type": "string" },
        "isAvailable": { "type": "boolean" }
      },
      "required": ["id", "businessId", "name"]
    }
  },
  "firestore": {
    "users": {
        "schema": "User",
        "description": "Collection of users."
    },
    "businesses": {
        "schema": "Business",
        "description": "Collection of businesses."
    },
    "businesses/{businessId}/services": {
        "schema": "Service",
        "description": "Subcollection of services for a business."
    },
    "businesses/{businessId}/staff": {
        "schema": "Staff",
        "description": "Subcollection of staff for a business."
    },
    "businesses/{businessId}/bookings": {
        "schema": "Booking",
        "description": "Subcollection of bookings for a business."
    }
  }
}
